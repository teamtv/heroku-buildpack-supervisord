#!/usr/bin/env bash
# bin/compile <build-dir> <cache-dir> <env-dir>
set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

SUPERVISORD_VERSION="${SUPERVISORD_VERSION:-0.7.3}"
TAR_FILE_NAME="supervisord_${SUPERVISORD_VERSION}_Linux_64-bit.tar.gz"

function topic() {
  echo "-----> $*"
}

if [ ! -f "${CACHE_DIR}/${TAR_FILE_NAME}" ]; then
  topic "Downloading supervisord ${SUPERVISORD_VERSION}"
  wget -q -P "${CACHE_DIR}" "https://github.com/ochinchina/supervisord/releases/download/v${SUPERVISORD_VERSION}/${TAR_FILE_NAME}"
else
  topic "Using cached supervisord ${SUPERVISORD_VERSION}"
fi

topic "Installing supervisord"
mkdir -p "${CACHE_DIR}/supervisord"
tar -xf "${CACHE_DIR}/${TAR_FILE_NAME}" -C "${CACHE_DIR}/supervisord" --strip-components=1

mkdir -p "${BUILD_DIR}/bin"
mv "${CACHE_DIR}/supervisord/supervisord" "${BUILD_DIR}/bin/supervisord"

mkdir -p "${BUILD_DIR}/.profile.d"
cat > "${BUILD_DIR}/.profile.d/supervisord.sh" <<'PROFILE'
export PATH="$HOME/bin:$PATH"
PROFILE
